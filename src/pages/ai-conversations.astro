---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const conversations = [
  {
    date: '04 Mar, 2025',
    title: 'UPI Activation Messages: How They Work and Security Measures',
    href: '/blog/upi-activation-messages-how-they-work-and-security-measures/',
  },
];
---
<BaseLayout title="AI Conversations" description="A collection of my conversations with AI that I found useful.">
  <Header />
  <main class="wrap">
    <article class="prose">
      <div class="post-meta">// ai-conversations</div>
      <h1 class="page-h1">ai conversations</h1>
      <p>All my conversations with AI which I deem useful.</p>
      <ul class="conv">
        {conversations.map((c) => (
          <li><span class="date">{c.date}</span> <a href={c.href}>{c.title}</a></li>
        ))}
      </ul>
    </article>
  </main>
  <Footer />
</BaseLayout>
<style>
  article { padding: 36px 0 0; }
  .post-meta { font-family: var(--mono); font-size: 13px; color: var(--fg-faint); margin-bottom: 14px; }
  .page-h1 { font-family: var(--mono); font-size: 28px; letter-spacing: -.5px; margin: 0 0 28px; }
  .conv { list-style: none; padding-left: 0; }
  .conv li { margin-bottom: 12px; }
  .conv .date { font-family: var(--mono); font-size: 12.5px; color: var(--fg-faint); margin-right: 8px; }
  .conv a { border-bottom: 1px solid var(--border); }
</style>
